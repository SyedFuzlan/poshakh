PORT=9000

# ── Owner Dashboard Login ───────────────────────────────────────────────────
OWNER_EMAIL=your@email.com
OWNER_PASSWORD=YourStrongPasswordHere

# ── JWT Secret ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_command_above

# ── Frontend URL (for CORS) ─────────────────────────────────────────────────
# In production, set this to your actual frontend domain: https://poshakh.in
STORE_CORS=http://localhost:3000

# ── Database ────────────────────────────────────────────────────────────────
# Leave blank to use default: ./data/poshakh.db
# For Railway: set to a path on a mounted volume
DATABASE_PATH=

# ── Razorpay ────────────────────────────────────────────────────────────────
# Test keys: https://dashboard.razorpay.com → Settings → API Keys (Test Mode)
# Switch to live keys before going live
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Set this in Razorpay dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=

# ── SMS (optional) ──────────────────────────────────────────────────────────
FAST2SMS_API_KEY=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
